# ──────────────────────────────────────────────────────────────────────
# DSTC Matching backend — environment template.
# Copy to .env and fill in real values. NEVER commit the real .env.
#
# In production these are read by the matching-api Quadlet container via
# EnvironmentFile= (see server/matching-api.container). When the backend
# runs on the supabase-net podman network, hosts resolve by container name.
#
# Public URLs:
#   Frontend  → https://matching.cteftu.id.vn
#   Backend   → https://matching-api.cteftu.id.vn
#   Supabase  → https://supabase.cteftu.id.vn
# ──────────────────────────────────────────────────────────────────────

# PostgreSQL connection string.
# - Container on the supabase-net network: host is `supabase-db`.
#   URL-encode the password if it contains special chars (+ / = etc.).
# - Bare metal (db published to 127.0.0.1:5432): host is `127.0.0.1`.
DATABASE_URL=postgresql://postgres:POSTGRES_PASSWORD@supabase-db:5432/postgres

# GoTrue endpoint.
# Through Kong (needs GOTRUE_SERVICE_KEY as the apikey header, matches CLAUDE.md):
GOTRUE_URL=http://supabase-kong:8000/auth/v1
# Or call GoTrue directly (no apikey needed): GOTRUE_URL=http://supabase-auth:9999
# Public path (via nginx, also valid in prod): GOTRUE_URL=https://supabase.cteftu.id.vn/auth/v1

# Supabase service_role JWT — used as the Kong `apikey` header.
GOTRUE_SERVICE_KEY=your-supabase-service-role-key

# MUST match GoTrue's JWT secret (supabase/.env JWT_SECRET).
JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters

# Comma-separated list of allowed frontend origins.
CORS_ORIGINS=https://matching.cteftu.id.vn,https://matching-api.cteftu.id.vn,http://localhost:5173
